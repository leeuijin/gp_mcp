🔍 상위 5개 SQL 상세 정보
1️⃣ 1위 - 설비 종합효율성점수 조회 쿼리
실행시간: 2026-03-25 10:05:44
수행총시간: 00:01:02.104891 (가장 오래 걸림)
CPU 사용량: 203
디스크 사용량: 0
Spill 파일 사용량: 0

WITH equipment_metrics AS (
  SELECT 
    e.equipment_id,
    e.equipment_name,
    e.line_name,
    -- 완료율 (20%)
    COALESCE(ROUND(100.0 * COUNT(CASE WHEN pl.status = 'COMPLETED' THEN 1 END) / 
             NULLIF(COUNT(DISTINCT pl.lot_id), 0), 2), 0) AS completion_rate,
    -- 품질합격률 (40%)
    COALESCE(ROUND(100.0 * COUNT(CASE WHEN qi.result = 'PASS' THEN 1 END) / 
             NULLIF(COUNT(qi.inspection_id), 0), 2), 0) AS quality_pass_rate,
    -- 설비안정성 (40%)
    COALESCE(ROUND(100.0 * COUNT(CASE WHEN el.status = 'NORMAL' THEN 1 END) / 
             NULLIF(COUNT(el.log_id), 0), 2), 0) AS stability_rate
  FROM equipment e
  LEFT JOIN production_lot pl ON e.equipment_id = pl.equipment_id
  LEFT JOIN quality_inspection qi ON pl.lot_id = qi.lot_id
  LEFT JOIN equipment_log el ON e.equipment_id = el.equipment_id
  GROUP BY e.equipment_id, e.equipment_name, e.line_name
)
SELECT 
  equipment_id AS 설비ID,
  equipment_name AS 설비명,
  line_name AS 라인명,
  completion_rate AS 완료율,
  quality_pass_rate AS 품질합격률,
  stability_rate AS 설비안정성,
  ROUND(
    (quality_pass_rate * 0.40) + 
    (stability_rate * 0.40) + 
    (completion_rate * 0.20), 2
  ) AS 종합효율성점수,
  CASE 
    WHEN ROUND(
      (quality_pass_rate * 0.40) + 
      (stability_rate * 0.40) + 
      (completion_rate * 0.20), 2) >= 95 THEN 'A+ 우수'
    WHEN ROUND(
      (quality_pass_rate * 0.40) + 
      (stability_rate * 0.40) + 
      (completion_rate * 0.20), 2) >= 90 THEN 'A 탁월'
    WHEN ROUND(
      (quality_pass_rate * 0.40) + 
      (stability_rate * 0.40) + 
      (completion_rate * 0.20), 2) >= 85 THEN 'B 양호'
    WHEN ROUND(
      (quality_pass_rate * 0.40) + 
      (stability_rate * 0.40) + 
      (completion_rate * 0.20), 2) >= 80 THEN 'C 보통'
    ELSE 'D 미흡'
  END AS 등급
FROM equipment_metrics
ORDER BY 종합효율성점수 DESC

2️⃣ 2위 - 설비별 월간 생산 통계 쿼리
실행시간: 2026-03-27 12:17:48
수행총시간: 00:00:07.503113
CPU 사용량: 0
디스크 사용량: 0
Spill 파일 사용량: 0

SELECT 
    e.equipment_id,
    e.equipment_name,
    e.line_name,
    DATE_TRUNC('month', pl.production_date)::DATE AS production_month,
    COUNT(DISTINCT pl.lot_id) AS total_lots,
    SUM(pl.quantity) AS total_quantity_produced,
    ROUND(AVG(pl.quantity), 2) AS avg_quantity_per_lot,
    COUNT(DISTINCT el.log_id) AS equipment_events,
    ROUND(AVG(el.temperature), 2) AS avg_temperature,
    ROUND(AVG(el.pressure), 2) AS avg_pressure,
    SUM(CASE WHEN el.status = 'ALERT' THEN 1 ELSE 0 END) AS alert_count,
    COUNT(DISTINCT qi.inspection_id) AS quality_inspections,
    SUM(CASE WHEN qi.result = 'FAIL' THEN 1 ELSE 0 END) AS failed_inspections,
    ROUND(SUM(CASE WHEN qi.result = 'FAIL' THEN 1 ELSE 0 END)::NUMERIC / 
          NULLIF(COUNT(DISTINCT qi.inspection_id), 0) * 100, 2) AS defect_rate_percent,
    ROUND(AVG(qi.defect_rate), 2) AS avg_defect_rate
FROM equipment e
LEFT JOIN production_lot pl ON e.equipment_id = pl.equipment_id
LEFT JOIN equipment_log el ON pl.lot_id = el.lot_id AND e.equipment_id = el.equipment_id
LEFT JOIN quality_inspection qi ON pl.lot_id = qi.lot_id
WHERE pl.production_date >= '2026-01-01' AND pl.production_date < '2026-07-01'
GROUP BY e.equipment_id, e.equipment_name, e.line_name, DATE_TRUNC('month', pl.production_date)
ORDER BY e.equipment_id, production_month

